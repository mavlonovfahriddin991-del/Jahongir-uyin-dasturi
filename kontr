<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Kosmik Otishma (Space Shooter)</title>
    <style>
        :root {
            --primary-color: #00f3ff;
            --danger-color: #ff0055;
            --bg-color: #050510;
            --ui-bg: rgba(255, 255, 255, 0.1);
            --font-main: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        }

        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
            user-select: none; /* Matnni ajratib olishni oldini oladi */
        }

        body {
            background-color: var(--bg-color);
            color: white;
            font-family: var(--font-main);
            overflow: hidden; /* Aylantirish chiziqlarini yashirish */
            height: 100vh;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
        }

        /* O'yin maydoni */
        #gameCanvas {
            border: 2px solid var(--primary-color);
            box-shadow: 0 0 20px rgba(0, 243, 255, 0.2);
            background: radial-gradient(circle at bottom, #1a1a2e 0%, #000000 100%);
            cursor: crosshair; /* Nishonbelgi */
            max-width: 100%;
            max-height: 100%;
        }

        /* UI elementlari (Ball, Hayot) */
        .hud {
            position: absolute;
            top: 20px;
            left: 20px;
            right: 20px;
            display: flex;
            justify-content: space-between;
            pointer-events: none; /* O'yinga xalaqit bermasligi uchun */
            z-index: 10;
        }

        .stat-box {
            background: var(--ui-bg);
            backdrop-filter: blur(5px);
            padding: 10px 20px;
            border-radius: 20px;
            border: 1px solid rgba(255, 255, 255, 0.2);
            font-size: 1.2rem;
            font-weight: bold;
            box-shadow: 0 4px 6px rgba(0,0,0,0.3);
        }

        .stat-label {
            color: #aaa;
            font-size: 0.8rem;
            margin-right: 5px;
        }

        /* Oynalar (Start, Game Over) */
        .modal {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: rgba(0, 0, 0, 0.85);
            display: flex;
            flex-direction: column;
            justify-content: center;
            align-items: center;
            z-index: 20;
            backdrop-filter: blur(8px);
            transition: opacity 0.3s ease;
        }

        .modal.hidden {
            opacity: 0;
            pointer-events: none;
        }

        .modal h1 {
            font-size: 3rem;
            margin-bottom: 10px;
            text-transform: uppercase;
            letter-spacing: 5px;
            background: linear-gradient(to right, var(--primary-color), #bc13fe);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            text-shadow: 0 0 20px rgba(0, 243, 255, 0.5);
        }

        .modal p {
            font-size: 1.1rem;
            color: #ddd;
            margin-bottom: 30px;
            max-width: 400px;
            text-align: center;
            line-height: 1.5;
        }

        .btn {
            padding: 15px 40px;
            font-size: 1.2rem;
            background: transparent;
            color: var(--primary-color);
            border: 2px solid var(--primary-color);
            border-radius: 50px;
            cursor: pointer;
            transition: all 0.3s ease;
            text-transform: uppercase;
            font-weight: bold;
            letter-spacing: 2px;
            position: relative;
            overflow: hidden;
        }

        .btn:hover {
            background: var(--primary-color);
            color: black;
            box-shadow: 0 0 30px var(--primary-color);
            transform: scale(1.05);
        }

        /* Mobil boshqaruv tugmalari */
        .mobile-controls {
            display: none; /* Kompyuterda yashirin */
            position: absolute;
            bottom: 20px;
            width: 100%;
            justify-content: space-between;
            padding: 0 20px;
            pointer-events: none; /* Faqat tugmalar bosilishi kerak */
        }

